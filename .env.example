# Server port (optional)
PORT=3000

# ─── Provider chain ────────────────────────────────────────────────────────────
# Comma-separated list of providers to try in order.
# Each provider is only used if its API key is set.
# Example: try Groq (free) → Gemini (free) → OpenAI (paid) as last resort.
PROVIDER_CHAIN=groq,gemini,openai

# ─── Groq (free tier — console.groq.com) ───────────────────────────────────────
GROQ_API_KEY=gsk-your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Google Gemini (free tier — aistudio.google.com/apikey) ────────────────────
GEMINI_API_KEY=AIza-your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# ─── OpenAI (paid fallback — platform.openai.com) ──────────────────────────────
# Set a monthly spend cap at platform.openai.com → Settings → Limits
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic (optional alternative paid provider) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── James Webb Space Telescope (free key — jwstapi.com) ───────────────────────
JWST_API_KEY=your-jwst-api-key-here

# ─── Rate limiting ─────────────────────────────────────────────────────────────
MAX_TOKENS=1024
RATE_LIMIT_WINDOW_MS=60000   # per-minute window (ms)
RATE_LIMIT_MAX_REQUESTS=30   # max requests per IP per minute
DAILY_LIMIT_PER_IP=50        # max messages per IP per day

# ─── Security ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://liamscall.com
# CHAT_API_TOKEN=your-secret-internal-token

# ─── Optional custom system prompt ─────────────────────────────────────────────
# SYSTEM_PROMPT=You are Liam's Call AI...
