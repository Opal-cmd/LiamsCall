# Server port (optional)
PORT=3000

# Choose primary provider: groq | openai | anthropic
AI_PROVIDER=groq

# Optional fallback provider (empty to disable)
FALLBACK_PROVIDER=

# Groq (free tier available at console.groq.com)
GROQ_API_KEY=gsk-your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=

# Anthropic (set AI_PROVIDER=anthropic to use)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_FALLBACK_MODEL=

# Optional limits
MAX_TOKENS=1024
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Optional security controls
# ALLOWED_ORIGIN=http://localhost:3000
# CHAT_API_TOKEN=your-secret-internal-token

# Logo file used by /assets/logo.png
# LOGO_FILE_PATH=C:\path\to\your\logo.png

# Optional custom system prompt
# SYSTEM_PROMPT=You are Caregiver.ai...
