# Server port (optional)
PORT=3000

# ─── Provider chain ────────────────────────────────────────────────────────────
# Comma-separated list of providers to try in order.
# Each provider is only used if its API key is set.
# Gemini first for quality; OpenAI optional paid fallback.
PROVIDER_CHAIN=gemini,openai

# ─── Google Gemini (free tier — aistudio.google.com/apikey) ────────────────────
GEMINI_API_KEY=AIza-your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash

# ─── Groq (optional — console.groq.com) ────────────────────────────────────────
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenAI (paid fallback — platform.openai.com) ──────────────────────────────
# Set a monthly spend cap at platform.openai.com → Settings → Limits
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic (optional alternative paid provider) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── James Webb Space Telescope (free key — jwstapi.com) ───────────────────────
JWST_API_KEY=your-jwst-api-key-here

# ─── Rate limiting ─────────────────────────────────────────────────────────────
MAX_TOKENS=2048
RATE_LIMIT_WINDOW_MS=60000   # per-minute window (ms)
RATE_LIMIT_MAX_REQUESTS=30   # max requests per IP per minute
DAILY_LIMIT_PER_IP=50        # max messages per IP per day

# Optional: Gemini reasoning. Default "none" so thinking tokens don't truncate replies.
# Values: none | low | medium | high
# GEMINI_REASONING_EFFORT=none

# ─── Cloudflare Turnstile (free — dash.cloudflare.com → Turnstile) ───────────
# Captcha is OFF until BOTH keys below are set.
#
# Hybrid shield (default behavior once keys are set):
#   - Normal browsers chat with no visible captcha.
#   - Suspicious visitors (bot UA, missing headers, rate spikes, etc.) see a challenge.
#   - Use a Managed widget in Cloudflare; the site uses appearance: interaction-only.
#
# Production setup:
#   1. Free Cloudflare account → Turnstile → Add widget
#   2. Hostnames: liamscall.com, liamscall.onrender.com, localhost (for local testing)
#   3. Widget mode: Managed (recommended)
#   4. Copy Site key + Secret key here and in Render env vars
#
# Optional: force captcha sooner when an IP nears the per-minute rate limit (0–1).
# CAPTCHA_RATE_FORCE_RATIO=0.7
#
# Local testing without a Cloudflare account (always passes):
# TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
#
# TURNSTILE_SITE_KEY=your-turnstile-site-key-here
# TURNSTILE_SECRET_KEY=your-turnstile-secret-key-here

# ─── Security ──────────────────────────────────────────────────────────────────
# Production only — comma-separated list of allowed site origins.
# Include every URL visitors may use (custom domain, www, and Render URL).
# ALLOWED_ORIGIN=https://liamscall.com,https://www.liamscall.com,https://liamscall.onrender.com
# No trailing slash — browsers send Origin without one (https://liamscall.com, not ...com/).
# CHAT_API_TOKEN=your-secret-internal-token

# ─── Optional custom system prompt ─────────────────────────────────────────────
# SYSTEM_PROMPT=You are Liam's Call AI...
